# -----------------------------------------------
# Clerk Authentication
# dashboard.clerk.com → your LinenLady app → API Keys
# -----------------------------------------------
# Clerk org ID that gets admin access
# Clerk dashboard → Organizations → your org → copy ID (org_...)
ADMIN_ORG_ID=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Same value, used client-side in SitePhoto.tsx
NEXT_PUBLIC_ADMIN_ORG_ID=

# -----------------------------------------------
# Store Identity (public — shown in UI)
# -----------------------------------------------
NEXT_PUBLIC_STORE_NAME=
NEXT_PUBLIC_SHORT_NAME=
NEXT_PUBLIC_ADMIN_NAME=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_CF_IMAGE_ZONE=

# -----------------------------------------------
# Backend API (C# Azure Functions)
# Change if your backend runs on a different port
# -----------------------------------------------
LINENLADY_API_BASE_URL=